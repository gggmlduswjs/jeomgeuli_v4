# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# OpenAI (Whisper STT)
OPENAI_API_KEY=sk-proj-...

# Anthropic (Claude + Claude Vision)
ANTHROPIC_API_KEY=sk-ant-...

# 하드웨어 시리얼 포트 (OS별)
# Windows: COM3
# macOS: /dev/tty.usbmodem1101
# Linux: /dev/ttyUSB0
SERIAL_PORT=COM3
SERIAL_BAUD=9600

# 3셀 훈련 기본 설정
DEFAULT_CELL_DURATION_SEC=2.0
